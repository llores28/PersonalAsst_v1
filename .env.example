# ──────────────────────────────────────
# REQUIRED — Application will not start without these
# ──────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...                         # Your OpenAI API key

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC...              # From @BotFather
OWNER_TELEGRAM_ID=123456789                   # Your Telegram numeric user ID

# Database
DB_PASSWORD=change_me_to_random_string        # PostgreSQL password

# ──────────────────────────────────────
# OPTIONAL — Defaults provided
# ──────────────────────────────────────

# Google Workspace (required for Phase 2+)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# LinkedIn (optional — for LinkedIn tool integration)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# OneDrive / Microsoft Graph (optional — for OneDrive file organization)
ONEDRIVE_ACCESS_TOKEN=
ONEDRIVE_REFRESH_TOKEN=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Web Search (optional — built-in WebSearchTool works without this)
TAVILY_API_KEY=

# Models (override defaults)
MODEL_ORCHESTRATOR=gpt-4.1
MODEL_CODE_GEN=gpt-4.1-mini
MODEL_FAST=gpt-4.1-nano
MODEL_GENERAL=gpt-4.1

# Cost Control
DAILY_COST_CAP_USD=5.00
MONTHLY_COST_CAP_USD=100.00

# Persona Defaults
DEFAULT_ASSISTANT_NAME=Atlas
DEFAULT_PERSONA_STYLE=friendly

# User Timezone
DEFAULT_TIMEZONE=America/New_York

# Security
MAX_TOOL_CALLS_PER_REQUEST=20
AGENT_TIMEOUT_SECONDS=120
TOOL_SUBPROCESS_TIMEOUT=30

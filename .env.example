# ──────────────────────────────────────
# REQUIRED — Application will not start without these
# ──────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...                         # Your OpenAI API key

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC...              # From @BotFather
OWNER_TELEGRAM_ID=123456789                   # Your Telegram numeric user ID

# Database
DB_PASSWORD=change_me_to_random_string        # PostgreSQL password

# ──────────────────────────────────────
# OPTIONAL — Defaults provided
# ──────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════════
# OPTION B UPGRADE — Multi-LLM Support (safe gradual rollout)
# ═══════════════════════════════════════════════════════════════════════════════

# Feature Flags — All default to false for zero disruption
MULTI_LLM_ENABLED=false                          # Enable multi-LLM provider switching
AGENT_MANAGED_SKILLS=false                       # Agent proposes skills from successful workflows
OPENROUTER_IMAGE_ENABLED=false                   # Enable OpenRouter image generation skill + Telegram image replies

# Default Provider (when MULTI_LLM_ENABLED=true)
DEFAULT_LLM_PROVIDER=openai                      # openai | anthropic | openrouter | google | local

# Provider API Keys (only needed if using that provider)
ANTHROPIC_API_KEY=sk-ant-...                     # For Claude models
OPENROUTER_API_KEY=sk-or-...                     # For 200+ models via OpenRouter
GOOGLE_API_KEY=...                               # For Gemini models
LOCAL_LLM_BASE_URL=http://localhost:11434/v1   # For Ollama, vLLM, etc.

# Per-Provider Cost Caps (when MULTI_LLM_ENABLED=true)
ANTHROPIC_DAILY_COST_CAP_USD=5.00
OPENROUTER_DAILY_COST_CAP_USD=5.00
GOOGLE_DAILY_COST_CAP_USD=5.00

# Skill Creation Settings (when AGENT_MANAGED_SKILLS=true)
SKILL_CONFIDENCE_THRESHOLD=0.8                   # Min confidence for agent to propose skill
SKILL_NUDGE_COOLDOWN_HOURS=24                    # Hours between skill suggestions
# SKILL_AUTO_APPROVE=false                       # DANGER: Skip approval (not recommended)

# ═══════════════════════════════════════════════════════════════════════════════
# END OPTION B UPGRADE
# ═══════════════════════════════════════════════════════════════════════════════

# Google Workspace (required for Phase 2+)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Workspace-MCP token-encryption key (required for token persistence).
# Generate ONCE with `openssl rand -hex 32` (or `python -c "import secrets;
# print(secrets.token_hex(32))"`) and never rotate without re-running
# `/connect google` for all users — rotation invalidates persisted tokens.
# If unset, the image derives a key from GOOGLE_OAUTH_CLIENT_SECRET, so a
# client-secret rotation would silently lock every user out.
WORKSPACE_MCP_SIGNING_KEY=

# LinkedIn (optional — for LinkedIn tool integration)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# OneDrive / Microsoft Graph (optional — for OneDrive file organization)
ONEDRIVE_ACCESS_TOKEN=
ONEDRIVE_REFRESH_TOKEN=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Web Search (optional — built-in WebSearchTool works without this)
TAVILY_API_KEY=

# Models (override defaults)
MODEL_ORCHESTRATOR=gpt-4.1
MODEL_CODE_GEN=gpt-4.1-mini
MODEL_FAST=gpt-4.1-nano
MODEL_GENERAL=gpt-4.1

# Cost Control
DAILY_COST_CAP_USD=5.00
MONTHLY_COST_CAP_USD=100.00

# Persona Defaults
DEFAULT_ASSISTANT_NAME=Atlas
DEFAULT_PERSONA_STYLE=friendly

# User Timezone
DEFAULT_TIMEZONE=America/New_York

# Security
MAX_TOOL_CALLS_PER_REQUEST=20
AGENT_TIMEOUT_SECONDS=120
TOOL_SUBPROCESS_TIMEOUT=30

# Startup Safety
STARTUP_MIGRATIONS_ENABLED=false               # Run Alembic on startup only when true

# Dashboard API CORS
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Dashboard API Authentication (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
DASHBOARD_API_KEY=

# Agentic Self-Healing (M4)
AUTO_REPAIR_LOW_RISK=true                      # Auto-apply low-risk operational fixes (Redis clears, schedule re-injections)

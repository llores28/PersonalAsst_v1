bootstrap/Nexus/

# Deprecated forked CLI copy — superseded by the editable Nexus/ install
# (`nexus` command). Kept on disk only as a historical artifact; do NOT
# re-track. See docs/CHANGELOG.md 2026-04-26 for the migration record.
bootstrap/

# Nexus toolkit clone — its own git repo, edited and committed elsewhere.
# Project consumes via editable pip install. Never commit from PersonalAsst.
Nexus/

# Nexus runtime state (regenerable; state.json, journal/, decisions/, dashboards)
.nexus/

# Per-project Nexus bootstrap doc — regenerated by `nexus init --refresh`
BOOTSTRAP.md

